# Copy this file to `.env` and adjust the values for your machine/profile.

# Candidate-specific values
TARS_CANDIDATE_DISPLAY_NAME=Candidate Name
TARS_CANDIDATE_FILENAME_PREFIX=VARDENIS_PAVARDENIS
TARS_APPLICANT_FIRST_NAME=Candidate
TARS_APPLICANT_LAST_NAME=Name
TARS_APPLICANT_LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-profile/
TARS_APPLICANT_EMAIL=candidate@example.com
TARS_APPLICANT_PHONE_COUNTRY_CODE=+358
TARS_APPLICANT_PHONE_LOCAL=401234567
TARS_APPLICANT_CITY=Helsinki
TARS_APPLICANT_DESIRED_SALARY=
TARS_APPLICANT_CITIZENSHIP_COUNTRIES=
TARS_APPLICANT_PERMANENT_RESIDENCY_COUNTRIES=
TARS_APPLICANT_READ_PRIVACY_APPROVED=YES
TARS_APPLICANT_AGREE_PRIVACY=YES
TARS_APPLICANT_PERSONAL_DATA_CONSENT=YES

# CV repository settings
TARS_CV_REPO_DIR=/home/your-user/cv
TARS_CV_MAIN_TEX=cv.tex

# Job keyword extraction for CV tailoring
TARS_KEYWORD_EXTRACTOR_MODE=hybrid
TARS_KEYWORD_EXTRACTOR_MODEL=
TARS_KEYWORD_EXTRACTOR_COMMAND=
TARS_KEYWORD_EXTRACTOR_OPENAI_API_KEY=
TARS_KEYWORD_EXTRACTOR_OPENAI_CHAT_URL=https://api.openai.com/v1/chat/completions

# Optional Chrome path override for Playwright
TARS_CHROME_PATH=/usr/bin/google-chrome

# Lifecycle / database / reporting
TARS_LIFECYCLE_DATABASE_URL=postgresql://user:password@localhost:5432/tars_lifecycle
TARS_LIFECYCLE_APPLICANT_POLICY_PATH=./lifecycle/policies/applicant_policy.json
TARS_LIFECYCLE_APPLICANT_FACTS_PATH=./lifecycle/policies/applicant_facts.json
TARS_LIFECYCLE_DASHBOARD_HOST=127.0.0.1
TARS_LIFECYCLE_DASHBOARD_PORT=4310
TARS_LIFECYCLE_SEARCH_BATCH_SIZE=5
TARS_LIFECYCLE_DISCOVERY_LIMIT=5
TARS_LIFECYCLE_MAX_APPLICATION_RETRIES=2
TARS_LIFECYCLE_RUN_TIMEOUT_MINUTES=20
TARS_LIFECYCLE_STALE_RUN_MINUTES=30
TARS_LIFECYCLE_SUMMARY_EMAIL_TO=you@example.com
TARS_LIFECYCLE_SUMMARY_EMAIL_FROM=tars@example.com
TARS_LIFECYCLE_SUMMARY_SMTP_HOST=smtp.gmail.com
TARS_LIFECYCLE_SUMMARY_SMTP_PORT=465
TARS_LIFECYCLE_SUMMARY_SMTP_SECURE=true
TARS_LIFECYCLE_SUMMARY_SMTP_USER=you@example.com
TARS_LIFECYCLE_SUMMARY_SMTP_PASS=app-password-here
